{
    /*
    Code Runner
    */
    "code-runner.executorMapByGlob": {
        "*.js": "bun",
        "*.ts": "bun"
    },
    "code-runner.runInTerminal": true,
    /*
    Cursor
    */
    "cursor.cpp.disabledLanguages": [
        "plaintext",
        "markdown",
        "scminput"
    ],
    /*
    Editor
    */
    "editor.accessibilitySupport": "off",
    "editor.formatOnSave": true, // run formatter on save
    "editor.guides.indentation": true,
    "editor.lightbulb.enabled": "off",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "always" // run linter on save
    },
    /*
    Files
    */
    "files.associations": {
        "*.css": "tailwindcss",
        "*.yml": "yaml"
    },
    "files.exclude": {
        "**/.git": false // show .git directory
    },
    /*
    Launch
    */
    "launch": {
        // https://go.microsoft.com/fwlink/?linkid=830387
        "version": "0.2.0",
        "configurations": [
            /*
            Bun Debugger configurations
            */
            {
                "type": "bun",
                "internalConsoleOptions": "neverOpen",
                "request": "launch",
                "name": "Bun: Debug File",
                "program": "${file}",
                "cwd": "${workspaceFolder}",
                "stopOnEntry": false,
                "watchMode": false
            },
            {
                "type": "bun",
                "internalConsoleOptions": "neverOpen",
                "request": "launch",
                "name": "Bun: Run File",
                "program": "${file}",
                "cwd": "${workspaceFolder}",
                "noDebug": true,
                "watchMode": false
            },
            {
                "type": "bun",
                "internalConsoleOptions": "neverOpen",
                "request": "attach",
                "name": "Bun: Attach",
                "url": "ws://localhost:6499/",
                "stopOnEntry": false
            }
        ]
    },
    /*
    Terminal
    */
    "bun.debugTerminal.enabled": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.fontFamily": "Menlo",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.lineHeight": 1,
    /*
    Security
    */
    "security.workspace.trust.untrustedFiles": "open", // turn off untrusted file dialog
    /*
    Workbench
    */
    "workbench.settings.editor": "ui",
    "workbench.startupEditor": "none",
    "workbench.sideBar.location": "left",
    /******************************
    Language-specific settings
    ******************************/
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.formatOnPaste": false,
        "editor.formatOnSave": false
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit",
        }
    },
    "[rego]": {
        "editor.formatOnPaste": false,
        "editor.formatOnSave": false
    },
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    /******************************
    Extension settings
    ******************************/
    /* CodeLLDB */
    "lldb.suppressUpdateNotifications": true,
}